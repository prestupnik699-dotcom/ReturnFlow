{
  "expo": {
    "name": "ReturnFlow",
    "slug": "returnflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "returnflow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.returnflow.app",
      "softwareKeyboardLayoutMode": "pan"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.returnflow.app"
    },
    "plugins": ["expo-router"]
  }
}
